generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id              String   @id @default(cuid())
  key             String   @unique
  title           String
  blurb           String
  anchor          String
  emailRecipient  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  products        Product[]
}

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  description   String
  imageUrl      String
  termLabel     String
  highlights    String[]
  hasSimulator  Boolean  @default(false)
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LoanConfig {
  id                  String   @id @default(cuid())
  valuationFee        Int      @default(1500)
  legalFee            Int      @default(1500)
  processingFee       Int      @default(15000)
  logbookTransferFee  Int      @default(2500)
  trackerFee          Int      @default(25000)
  monthlyRate         Float    @default(0.06)
  minMonths           Int      @default(1)
  maxMonths           Int      @default(6)
  updatedAt           DateTime @updatedAt
  updatedBy           String   @default("system")
}

model Lead {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String
  category        String
  subject         String?
  message         String?
  fundingCategory String?
  opportunityType String?
  track           String?
  ticket          String?
  description     String?
  notes           String?
  status          String   @default("new")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([createdAt])
}

model EmailConfig {
  id                String @id @default(cuid())
  categoryLoans     String @default("loans@abzcapital.co.ke")
  categoryInsurance String @default("cover@abzcapital.co.ke")
  categoryInvest    String @default("invest@abzcapital.co.ke")
  categoryGeneral   String @default("hello@abzcapital.co.ke")
  updatedAt         DateTime @updatedAt
}

// Auth.js Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          String    @default("investor") // admin | investor
  accounts      Account[]
  sessions      Session[]
  investor      Investor?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id        String   @id @default(cuid())
  sessionToken String  @unique
  userId    String
  expires   DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Investor Profile
model Investor {
  id              String    @id @default(cuid())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String    @unique
  companyName     String?
  country         String?
  ticketSize      String?   // <500K | 500K-2M | 2M-10M | >10M
  investmentTrack String?   // asset-backed | sme-innovation
  kycStatus       String    @default("pending") // pending | submitted | approved | rejected
  kycDocuments    String[]  // URLs to uploaded documents
  pitchDeckUrl    String?
  investmentHistory String? // JSON field for deal history
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deals           InvestorDeal[]
}

// Deal visibility for investors
model InvestorDeal {
  id        String    @id @default(cuid())
  investor  Investor  @relation(fields: [investorId], references: [id], onDelete: Cascade)
  investorId String
  leadId    String    // References Lead from Phase 1
  status    String    @default("new") // new | interested | offered | closed
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([investorId, leadId])
  @@index([investorId])
  @@index([status])
}
